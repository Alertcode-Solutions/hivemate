VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000
VITE_GOOGLE_CLIENT_ID=

# WebRTC (Production): configure TURN to reliably connect calls behind mobile/carrier NAT.
# Option A (preferred): provide full ICE list as JSON array.
# VITE_WEBRTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.yourdomain.com:3478?transport=udp","turns:turn.yourdomain.com:5349?transport=tcp"],"username":"user","credential":"pass"}]
#
# Option B: separate variables.
# VITE_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# VITE_WEBRTC_TURN_URL=turn:turn.yourdomain.com:3478?transport=udp,turns:turn.yourdomain.com:5349?transport=tcp
# VITE_WEBRTC_TURN_USERNAME=
# VITE_WEBRTC_TURN_CREDENTIAL=
